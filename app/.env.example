# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and update values as needed:
#   cp .env.example .env
#
# IMPORTANT: .env contains real credentials and is gitignored.
#            .env.example is committed as documentation.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Used by both the postgres container (to create the database on first run)
# and by the API container (to construct the DATABASE_URL connection string).
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ecommerce

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# DATABASE_URL: Connection string for the API to reach PostgreSQL.
# "db" is the Docker Compose service name -- Docker DNS resolves it
# to the PostgreSQL container's IP address on the internal network.
DATABASE_URL=postgresql://ecommerce:changeme@db:5432/ecommerce

# REDIS_URL: Connection string for the API to reach Redis.
# "redis" is the Docker Compose service name.
REDIS_URL=redis://redis:6379

# PORT: Which port the Node.js API listens on inside the container.
PORT=3000

# NODE_ENV: Controls Express behavior and other library defaults.
# Use "development" locally, "production" in prod override.
NODE_ENV=development
